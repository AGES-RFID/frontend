{
  "name": "front",
  "module": "index.ts",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun --hot public/index.html",
    "build": "bun run build.ts",
    "typecheck": "tsc --noEmit",
    "format": "biome format",
    "lint": "biome lint",
    "check": "bun run typecheck && bun run lint && bun run format",
    "check:fix": "bun run typecheck && bun run lint --write --unsafe && bun run format --write && git update-index --again",
    "test": "bun test",
    "test:cov": "bun test --coverage --coverage-reporter=text --coverage-reporter=lcov",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@happy-dom/global-registrator": "^20.8.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "bun-plugin-tailwind": "^0.1.2",
    "husky": "^9.1.7",
    "tailwindcss": "^4.2.1"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  }
}
